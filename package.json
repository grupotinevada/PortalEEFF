{
  "name": "portal-eeff",
  "version": "3.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "dev": "concurrently -k -n BACKEND,FRONTEND -c bgBlue.bold,bgGreen.bold \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:qa": "concurrently -k -n BACKEND,FRONTEND -c blue,green \"npm run dev:backend\" \"npm run dev:frontend:qa\"",
    "dev:backend": "nodemon --watch . --ext js,json --exec node server.js",
    "dev:frontend": "ng serve",
    "dev:frontend:qa": "ng serve --configuration qa"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/material": "^20.1.0",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-server": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@angular/service-worker": "^20.3.18",
    "@angular/ssr": "^20.2.1",
    "@azure/msal-node": "^3.8.0",
    "@ng-bootstrap/ng-bootstrap": "^19.0.0",
    "@ng-select/ng-select": "^20.2.0",
    "@popperjs/core": "^2.11.8",
    "@primeuix/themes": "^1.2.5",
    "@swimlane/ngx-charts": "^23.1.0",
    "bcryptjs": "^3.0.2",
    "bootstrap": "^5.3.7",
    "bootstrap-icons": "^1.13.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "file-saver": "^2.0.5",
    "helmet": "^8.1.0",
    "jquery": "^3.7.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.1",
    "primeng": "^20.2.0",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.22.2",
    "tslib": "^2.3.0",
    "xlsx-js-style": "^1.2.0",
    "zone.js": "~0.15.0"
  },
